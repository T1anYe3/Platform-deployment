# Platform 2 Docker Deployment - Environment Variables
# Copy to .env and customize before deployment
#   cp .env.example .env

# MinIO (Object Storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=ChangeThis-Local-123!

# NiFi (Data Flow Orchestration)
NIFI_WEB_HTTPS_PORT=8443
NIFI_ADMIN_USER=admin
NIFI_ADMIN_PASS=Admin123!ChangeMe

# Vault (Secrets Management)
VAULT_DEV_ROOT_TOKEN_ID=platform2-root-token

# Elasticsearch
ES_MEMORY=2g

# Platform domain / IP
PLATFORM_DOMAIN=localhost

# ---- Auto-generated by init.sh --secure ----
# ELASTIC_PASSWORD=
# KIBANA_SYSTEM_PASSWORD=
