# Platform 1 Docker Deployment - Environment Variables
# Copy to .env and customize before deployment

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=ChangeThis-Local-123!

# NiFi
NIFI_WEB_HTTPS_PORT=8443
NIFI_ADMIN_USER=admin
NIFI_ADMIN_PASS=Admin123!ChangeMe

# Vault
VAULT_DEV_ROOT_TOKEN_ID=platform1-root-token

# SafeLine WAF (deployed separately via its own installer)
# These credentials are used by bridge-safeline.py to connect to SafeLine
SAFELINE_ADMIN_USER=admin
SAFELINE_ADMIN_PASS=w4WmJByY

# Elasticsearch
ES_MEMORY=2g

# Platform domain / IP
PLATFORM_DOMAIN=localhost
