# Platform 3 - Compliance & Emergency Response Platform
# Environment Variables
# Copy to .env and customize before deployment
#   cp .env.example .env

# Elasticsearch
ES_MEMORY=2g
ES_MEM_LIMIT=3g
ES_CPUS=2
ES_SECURITY_ENABLED=false

# Vault (lightweight credential management)
# VAULT_DEV_ROOT_TOKEN_ID=platform3-root-token

# Platform domain / IP
PLATFORM_DOMAIN=localhost

# Service binding (127.0.0.1 = local access only, 0.0.0.0 = LAN access)
BIND_ADDRESS=127.0.0.1

# ---- Auto-generated by init.sh --secure ----
# ELASTIC_PASSWORD=
# KIBANA_ES_PASSWORD=
# KIBANA_ENCRYPTION_KEY=
